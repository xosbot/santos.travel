# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=santos_travel
DB_USER=santos
DB_PASSWORD=

# ── LLM ──────────────────────────────────────────────────
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
EXTRACTION_MODEL=gpt-4o
PROSE_MODEL=gpt-4o

# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Auth ──────────────────────────────────────────────────
# Comma-separated API keys. Leave empty for dev (no auth).
# Generate with: node -e "console.log(require('./src/middleware/auth').generateApiKey())"
API_KEYS=

# ── PDF ──────────────────────────────────────────────────
PUPPETEER_DISABLE=true
