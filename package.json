{
  "name": "santos-travel-iva",
  "version": "0.1.0",
  "private": true,
  "description": "IVA Cortex — Intelligent Virtual Assistant for Santos Travel",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test 'tests/**/*.test.js'",
    "demo": "node scripts/demo-pipeline.js",
    "start:dev": "bash scripts/start-dev.sh",
    "db:migrate": "psql \"$DATABASE_URL\" < db/schema.sql",
    "db:seed": "psql \"$DATABASE_URL\" < db/seed.sql",
    "db:reset": "psql \"$DATABASE_URL\" -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public;' && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "pg": "^8.13.0",
    "puppeteer": "^25.1.0",
    "zod": "^4.4.3"
  }
}
